<Window x:Class="WordViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Word Viewer"
        Height="900" Width="1200"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ChromeBackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseDocumentCommand}" />
        <KeyBinding Key="F5"                 Command="{Binding ReloadCommand}" />
        <KeyBinding Key="Add"      Modifiers="Ctrl" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="OemPlus"  Modifiers="Ctrl" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="Subtract" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="D0"       Modifiers="Ctrl" Command="{Binding ZoomResetCommand}" />
        <KeyBinding Key="NumPad0"  Modifiers="Ctrl" Command="{Binding ZoomResetCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Toolbar -->
            <RowDefinition Height="*" />       <!-- Content -->
            <RowDefinition Height="Auto" />   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ TOOLBAR -->
        <Border Grid.Row="0"
                Background="{StaticResource ChromeBackgroundBrush}"
                BorderBrush="{StaticResource ChromeBorderBrush}"
                BorderThickness="0,0,0,1">
            <ToolBar Background="Transparent"
                     BorderThickness="0"
                     Padding="6,4">
                <ToolBar.Resources>
                    <!-- Kill the default overflow grip -->
                    <Style TargetType="ToolBarPanel">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </ToolBar.Resources>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding OpenCommand}"
                        ToolTip="Open document (Ctrl+O)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Open" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource ToolbarSeparatorStyle}" />

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ReloadCommand}"
                        ToolTip="Reload document (F5)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Reload" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding CloseDocumentCommand}"
                        ToolTip="Close document (Ctrl+W)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Close" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource ToolbarSeparatorStyle}" />

                <!-- Zoom controls -->
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ZoomOutCommand}"
                        ToolTip="Zoom out (Ctrl+-)">
                    <TextBlock Text="&#xE71F;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                </Button>

                <TextBlock x:Name="ZoomLabel"
                           Text="{Binding ZoomText}"
                           Foreground="{StaticResource ToolbarTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Width="46"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="2,0" />

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ZoomInCommand}"
                        ToolTip="Zoom in (Ctrl++)">
                    <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                </Button>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ZoomResetCommand}"
                        ToolTip="Reset zoom (Ctrl+0)"
                        Padding="8,6">
                    <TextBlock Text="100%" FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center" />
                </Button>

            </ToolBar>
        </Border>

        <!-- ════════════════════════════════════════════════ MAIN CONTENT -->
        <Grid Grid.Row="1">

            <!-- Welcome / drop zone (shown when no document is loaded) -->
            <Border x:Name="WelcomePanel"
                    Background="#FF1E1E1E"
                    Visibility="{Binding WelcomeVisibility}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            AllowDrop="True"
                            Drop="OnDrop"
                            DragOver="OnDragOver">
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="64"
                               Foreground="#FF555558"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />
                    <TextBlock Text="Open a Word Document"
                               FontFamily="Segoe UI Light"
                               FontSize="24"
                               Foreground="#FF999999"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Click Open or drag and drop a .docx file here"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Foreground="#FF666666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,28" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Background="{StaticResource AccentBrush}"
                            Command="{Binding OpenCommand}"
                            Padding="24,10"
                            FontSize="14"
                            HorizontalAlignment="Center"
                            Content="Browse for a file..." />
                </StackPanel>
            </Border>

            <!-- WebView2 document renderer -->
            <wv2:WebView2 x:Name="WebView"
                          Visibility="{Binding DocumentVisibility}"
                          AllowDrop="True"
                          Drop="OnDrop"
                          DragOver="OnDragOver" />

            <!-- Loading overlay -->
            <Border x:Name="LoadingOverlay"
                    Background="#CC1E1E1E"
                    Visibility="{Binding LoadingVisibility}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Converting document..."
                               FontFamily="Segoe UI"
                               FontSize="16"
                               Foreground="#FFE0E0E0"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <ProgressBar IsIndeterminate="True"
                                 Width="240"
                                 Height="4"
                                 Background="#FF3F3F46"
                                 Foreground="{StaticResource AccentBrush}" />
                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════ STATUS BAR -->
        <Border Grid.Row="2"
                Background="{StaticResource StatusBarBackgroundBrush}"
                Height="24">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="White"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Column="1"
                           Text="{Binding WarningText}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FFFFCC00"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           Visibility="{Binding WarningVisibility}" />
            </Grid>
        </Border>

    </Grid>
</Window>
