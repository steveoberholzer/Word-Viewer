<Application x:Class="WordViewer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- Base colours -->
        <Color x:Key="ChromeBackgroundColor">#FF2D2D30</Color>
        <Color x:Key="ChromeBorderColor">#FF3F3F46</Color>
        <Color x:Key="AccentColor">#FF0078D4</Color>
        <Color x:Key="AccentHoverColor">#FF1A86DA</Color>
        <Color x:Key="AccentPressedColor">#FF006CBE</Color>
        <Color x:Key="ToolbarTextColor">#FFE0E0E0</Color>
        <Color x:Key="StatusBarBackgroundColor">#FF007ACC</Color>

        <SolidColorBrush x:Key="ChromeBackgroundBrush"  Color="{StaticResource ChromeBackgroundColor}" />
        <SolidColorBrush x:Key="ChromeBorderBrush"      Color="{StaticResource ChromeBorderColor}" />
        <SolidColorBrush x:Key="AccentBrush"            Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentHoverBrush"       Color="{StaticResource AccentHoverColor}" />
        <SolidColorBrush x:Key="AccentPressedBrush"     Color="{StaticResource AccentPressedColor}" />
        <SolidColorBrush x:Key="ToolbarTextBrush"       Color="{StaticResource ToolbarTextColor}" />
        <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="{StaticResource StatusBarBackgroundColor}" />

        <!-- Toolbar button style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{StaticResource ToolbarTextBrush}" />
            <Setter Property="BorderBrush"  Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"      Value="12,6" />
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="FontFamily"   Value="Segoe UI" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator style for toolbar -->
        <Style x:Key="ToolbarSeparatorStyle" TargetType="Separator">
            <Setter Property="Background"        Value="#FF555558" />
            <Setter Property="Width"             Value="1" />
            <Setter Property="Margin"            Value="4,6" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

    </Application.Resources>
</Application>
